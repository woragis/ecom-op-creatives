# Copy to .env and fill in keys for real AI:
#   cp .env.example .env

# --- Required for real pipeline (disable all mocks below) ---
LLM_MOCK=0
SERPER_MOCK=0
ELEVENLABS_MOCK=0
IMAGE_MOCK=0
VIDEO_MOCK=0
SUBTITLES_MOCK=0
RENDER_MOCK=0
POSTPROCESS_MOCK=0

# --- LLM agents (research, hooks, script, director, prompter, supervisor) ---
OPENAI_API_KEY=sk-...
# Optional if LLM_DEFAULT_PROVIDER=anthropic
ANTHROPIC_API_KEY=
LLM_DEFAULT_PROVIDER=openai

# --- Product research (web search) ---
SERPER_API_KEY=

# --- Voice narration ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# --- Image generation (pick one provider; set IMAGE_PROVIDER_DEFAULT) ---
IMAGE_PROVIDER_DEFAULT=flux
FLUX_API_KEY=
# dalle uses OPENAI_API_KEY
IDEOGRAM_API_KEY=
STABILITY_API_KEY=

# --- Video generation (pick one provider; set VIDEO_PROVIDER_DEFAULT) ---
VIDEO_PROVIDER_DEFAULT=kling
KLING_API_KEY=
RUNWAY_API_KEY=
LUMA_API_KEY=
GOOGLE_VEO_API_KEY=

# --- Public API URL ---
# Browser + frontend use localhost. Video APIs (image2video) need a URL they can
# fetch from the internet — use ngrok/cloudflare tunnel pointing to :8080.
API_PUBLIC_URL=http://localhost:8080
NEXT_PUBLIC_API_URL=http://localhost:8080

# --- Optional tuning ---
AUTH_JWT_SECRET=change-me
SUPERVISOR_MIN_SCORE=75
INTRO_DURATION_MS=2500
IMAGE_MAX_SCENES=3
VIDEO_MAX_SCENES=3

# --- Dev with mocks (no API keys) ---
# LLM_MOCK=1
# SERPER_MOCK=1
# ELEVENLABS_MOCK=1
# IMAGE_MOCK=1
# VIDEO_MOCK=1
# SUBTITLES_MOCK=1
# RENDER_MOCK=1
# POSTPROCESS_MOCK=1
